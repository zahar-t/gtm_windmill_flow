# GTM Engine secrets — copy to .env for local dev.
# In production these are injected by Windmill as environment variables
# (Windmill Variables u/admin/<NAME> surface as env var <NAME>).
# Scripts read ONLY from os.environ — never wmill.get_variable(), never hardcoded.

# --- Intake ---
EXA_API_KEY=
APIFY_API_TOKEN=
APIFY_LINKEDIN_ACTOR_ID=dev_fusion~linkedin-profile-scraper
# Optional LinkedIn *search* actor for cold-lead discovery (else Exa is used).
APIFY_LINKEDIN_SEARCH_ACTOR_ID=
# --- Unipile (warm LinkedIn engagement: profile viewers + post reactors/commenters) ---
# DSN is host:port from the Unipile dashboard (no scheme), e.g. api1.unipile.com:13111.
# All blank -> the ~20-min engagement poll no-ops. Requires a LinkedIn account
# linked via Unipile hosted auth.
UNIPILE_DSN=
UNIPILE_API_KEY=
UNIPILE_ACCOUNT_ID=
# Raw LinkedIn endpoint for "who viewed your profile" (passthrough). Blank ->
# profile-viewers skipped; post reactions/comments still run. Premium/Sales Nav
# gives the full viewer list.
UNIPILE_PROFILE_VIEWS_PATH=
UNIPILE_POST_LOOKBACK=5
# Daily volume floor — below this, cold discovery tops up the batch.
MIN_DAILY_LEADS=25

# --- Enrichment (email waterfall: Hunter -> Apollo -> PDL) ---
HUNTER_API_KEY=
APOLLO_API_KEY=
PDL_API_KEY=
# Company data: Proxycurl primary, Clearbit fallback
PROXYCURL_API_KEY=
CLEARBIT_API_KEY=

# --- Funding feed (PRIMARY source) ---
# Provider-agnostic. crunchbase (concrete) | dealroom | sifted (seams). Blank key -> no-op.
FUNDING_PROVIDER=crunchbase
CRUNCHBASE_API_KEY=
DEALROOM_API_KEY=
SIFTED_API_KEY=
FUNDING_LOOKBACK_DAYS=7
# Restrict funding intake to ISO-2 countries (csv); blank = no country filter.
FUNDING_COUNTRIES=

# --- Priority scoring (funding recency x round-size dominate) ---
PRIORITY_TAU_DAYS=14
PRIORITY_SIZE_CAP_EUR=50000000
PRIORITY_W_RECENCY=0.40
PRIORITY_W_SIZE=0.40
PRIORITY_W_RELEVANCE=0.20
# Optional per-signal relevance override, csv k:v (else built-in funding>job_change>...).
RELEVANCE_WEIGHTS=

# --- Investor graph + channel router ---
# Funds we can get warm intros from (csv) -> channel=investor_intro.
RELATIONSHIP_INVESTORS=
# LinkedIn touch falls back to email after N days with no reply.
LINKEDIN_FALLBACK_DAYS=5

# --- AI ---
ANTHROPIC_API_KEY=

# --- CRM ---
SUPABASE_URL=
SUPABASE_KEY=

# --- Email: Instantly (cold-outreach send + warmup + open/reply/bounce tracking) ---
INSTANTLY_API_KEY=
INSTANTLY_BASE_URL=https://api.instantly.ai/api/v2
INSTANTLY_CAMPAIGN_ID=
# From-identity for labels/domain hint (Instantly sets the real sender per mailbox).
SENDGRID_FROM_EMAIL=outbound@example.com
SENDGRID_FROM_NAME=GTM Engine
# Legacy — cold pipeline no longer sends/tracks via SendGrid.
SENDGRID_API_KEY=

# --- Deliverability: spam content scoring (pre-send guard) ---
# spam_score 0-100; >= block holds the send, >= review flags it. Tune as needed.
SPAM_REVIEW_THRESHOLD=40
SPAM_BLOCK_THRESHOLD=70

# --- Email validation (pre-send deliverability check, node 9) ---
# Verify addresses before drafting/sending. Blank keys -> validation no-ops.
# provider: zerobounce (default) | neverbounce. Set the key for whichever you use.
EMAIL_VERIFY_PROVIDER=zerobounce
ZEROBOUNCE_API_KEY=
NEVERBOUNCE_API_KEY=
# Catch-all/unknown domains can't be confirmed; true = still send, false = suppress.
EMAIL_VERIFY_ALLOW_CATCHALL=true

# --- Lifecycle: multi-touch follow-up + reply suppression ---
FOLLOWUP_GAP_DAYS=4
MAX_TOUCHES=3
SUPPRESS_OUTCOMES=reply,bounce,unsubscribe

# --- Deliverability: postmaster / reputation layer ---
# Sending domain to monitor for Gmail reputation (e.g. mail.example.com).
POSTMASTER_DOMAIN=
# Optional Google Postmaster Tools OAuth bearer token (service account / OAuth).
GOOGLE_POSTMASTER_TOKEN=
# Bounce rate comes from Instantly analytics (INSTANTLY_API_KEY above); Gmail
# spam ratio + auth from Google Postmaster — no extra key needed.
POSTMASTER_LOOKBACK_DAYS=7
# Reputation thresholds (fractions of sends). Defaults: 0.1%/0.3% complaint, 2%/5% bounce.
POSTMASTER_SPAM_WATCH=0.001
POSTMASTER_SPAM_CRITICAL=0.003
POSTMASTER_BOUNCE_WATCH=0.02
POSTMASTER_BOUNCE_CRITICAL=0.05

# --- Notifications ---
SLACK_WEBHOOK_URL=
